@page
@model ErrorModel
@{
    ViewData["Title"] = "エラー";
}

<section class="placeholder-page">
    <p class="store-home__eyebrow">エラー</p>
    <h1>処理中にエラーが発生しました</h1>
    <p>時間をおいて再度お試しください。</p>

    @if (Model.ShowRequestId)
    {
        <p class="text-muted">Request ID: <code>@Model.RequestId</code></p>
    }

    <a class="btn btn-outline-secondary btn-lg" asp-page="/Index">ホームへ戻る</a>
</section>
