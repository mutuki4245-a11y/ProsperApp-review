@inject IFeatureGate FeatureGate
@inject ILocalSettingsProvider LocalSettingsProvider
<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#102a43" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="店舗アプリ" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <title>@ViewData["Title"] - 店舗用アプリ</title>
    <script type="importmap"></script>
    <link rel="manifest" href="~/site.webmanifest" />
    <link rel="icon" type="image/svg+xml" href="~/icons/store-app-icon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="~/icons/apple-touch-icon.png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ProsperApp.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">店舗用アプリ</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="ナビゲーション切り替え">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Index">ホーム</a>
                        </li>
                        @if (FeatureGate.IsEnabled(FeatureNames.Settings))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-page="/Settings/Index">設定</a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            var storeName = LocalSettingsProvider.GetCurrent().StoreName;
                            <li class="nav-item">
                                <span class="navbar-text text-dark">@storeName</span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" href="/logout">ログアウト</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/Login">ログイン</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container-fluid app-shell">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <div class="app-loading-overlay" id="appLoadingOverlay" role="status" aria-live="polite" aria-hidden="true">
        <div class="app-loading-overlay__panel">
            <div class="spinner-border text-primary" aria-hidden="true"></div>
            <strong>処理中です</strong>
        </div>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - 店舗用アプリ
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (() => {
            const key = "ProsperApp.LocalSettings";
            if (document.cookie.includes(`${key}=`)) {
                return;
            }

            const value = localStorage.getItem(key);
            if (!value) {
                return;
            }

            document.cookie = `${key}=${encodeURIComponent(value)}; path=/; max-age=31536000; samesite=lax`;
        })();
    </script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
