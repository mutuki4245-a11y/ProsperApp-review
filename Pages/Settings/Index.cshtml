@page
@using System.Text.Json
@using ProsperApp.Models
@model SettingsModel
@{
    ViewData["Title"] = "設定";
}

<section class="settings-page">
    <div class="store-home__hero">
        <p class="store-home__eyebrow">管理者用</p>
        <h1>設定</h1>
        <p>店舗設定、機能設定、管理者モード、勤怠入力の時刻刻みをこの端末に保存します。</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="alert alert-success">@Model.SuccessMessage</div>
    }

    @if (!Model.IsUnlocked)
    {
        <form method="post" asp-page-handler="Unlock" class="settings-card settings-login">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <h2>パスワード確認</h2>
            <p class="text-muted">設定を開くには管理者パスワードを入力してください。解除状態は保存されません。</p>

            <label asp-for="Password" class="form-label"></label>
            <input asp-for="Password" class="form-control form-control-lg" type="password" inputmode="numeric" autocomplete="off" autofocus />
            <span asp-validation-for="Password" class="text-danger"></span>

            <div class="settings-actions">
                <button class="btn btn-primary btn-lg" type="submit">設定を開く</button>
                <a class="btn btn-outline-secondary btn-lg" asp-page="/Index">ホームへ戻る</a>
            </div>
        </form>
    }
    else
    {
        <form method="post" asp-page-handler="Save" class="settings-form">
            <input type="hidden" asp-for="SaveToken" />
            <input type="hidden" asp-for="Input.StoreName" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <section class="settings-card">
                <h2>店舗設定</h2>
                <p class="text-muted mb-3">department_masterから利用店舗を選択します。選択した店舗は、この端末の営業日、伝票、領収書入力の参照・作成・更新に使われます。</p>
                @if (Model.Departments.Count == 0)
                {
                    <div class="alert alert-warning">
                        <strong>店舗一覧を取得できません。</strong>
                        <div>@(Model.StoreSettingsDiagnosticMessage ?? "原因を特定できませんでした。")</div>
                        @if (!string.IsNullOrWhiteSpace(Model.StoreSettingsRpcStatus) || !string.IsNullOrWhiteSpace(Model.StoreSettingsTableStatus))
                        {
                            <hr />
                            <div class="small">
                                @if (!string.IsNullOrWhiteSpace(Model.StoreSettingsRpcStatus))
                                {
                                    <div>RPC: @Model.StoreSettingsRpcStatus</div>
                                }
                                @if (!string.IsNullOrWhiteSpace(Model.StoreSettingsTableStatus))
                                {
                                    <div>REST: @Model.StoreSettingsTableStatus</div>
                                }
                            </div>
                        }
                    </div>
                }
                <label asp-for="Input.StoreDepartmentId" class="form-label"></label>
                <select asp-for="Input.StoreDepartmentId" class="form-select form-select-lg">
                    <option value="">店舗を選択してください</option>
                    @foreach (var department in Model.Departments)
                    {
                        <option value="@department.DepartmentId">
                            @department.DisplayName
                        </option>
                    }
                </select>
                <span asp-validation-for="Input.StoreDepartmentId" class="text-danger"></span>
                <div class="form-text">Cookieがない場合だけ、appsettingsのSupabase:StoreDepartmentIdを使います。</div>
            </section>

            <section class="settings-card">
                <h2>機能設定</h2>
                <div class="settings-radio-grid">
                    <label class="settings-radio">
                        <input asp-for="Input.ScreenMode" type="radio" value="sales-management" />
                        <span>
                            <strong>営業管理用画面</strong>
                            <small>営業準備、営業中、締め作業を使う店舗運用画面</small>
                        </span>
                    </label>
                    <label class="settings-radio">
                        <input asp-for="Input.ScreenMode" type="radio" value="order-entry" />
                        <span>
                            <strong>オーダー登録用画面</strong>
                            <small>後続実装予定のオーダー登録専用画面で利用する設定</small>
                        </span>
                    </label>
                </div>
                <span asp-validation-for="Input.ScreenMode" class="text-danger"></span>
                <label class="settings-radio mt-3">
                    <input asp-for="Input.IsAdminMode" type="checkbox" />
                    <span>
                        <strong>管理者モード</strong>
                        <small>カテゴリ追加など、管理者向けの編集項目を表示する</small>
                    </span>
                </label>
            </section>

            <section class="settings-card">
                <h2>勤怠設定</h2>
                <label asp-for="Input.AttendanceMinuteStep" class="form-label"></label>
                <div class="settings-radio-grid settings-radio-grid--compact">
                    <label class="settings-radio">
                        <input asp-for="Input.AttendanceMinuteStep" type="radio" value="15" />
                        <span>
                            <strong>15分刻み</strong>
                            <small>細かく勤怠時刻を入力する</small>
                        </span>
                    </label>
                    <label class="settings-radio">
                        <input asp-for="Input.AttendanceMinuteStep" type="radio" value="30" />
                        <span>
                            <strong>30分刻み</strong>
                            <small>入力速度を優先する</small>
                        </span>
                    </label>
                </div>
                <span asp-validation-for="Input.AttendanceMinuteStep" class="text-danger"></span>
            </section>

            <div class="settings-actions">
                <button class="btn btn-primary btn-lg" type="submit">設定を保存</button>
                <button class="btn btn-outline-danger btn-lg" type="submit" formaction="?handler=Lock">ロックする</button>
                <a class="btn btn-outline-secondary btn-lg" asp-page="/Index">ホームへ戻る</a>
            </div>
        </form>
    }
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    @if (!string.IsNullOrWhiteSpace(Model.LocalSettingsJsonForClient))
    {
        <script>
            localStorage.setItem(
                @JsonSerializer.Serialize(LocalSettings.LocalStorageKey),
                @Html.Raw(JsonSerializer.Serialize(Model.LocalSettingsJsonForClient)));
        </script>
    }
}
